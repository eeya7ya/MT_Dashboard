# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored.

# Secret used to sign session cookies. MUST be at least 32 characters.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# JSON array of users with scrypt-hashed passwords. Generate entries with:
#   node scripts/hash-password.mjs <username> '<password>'
# Example (replace with your own hash):
# AUTH_USERS='[{"username":"yahya","salt":"<hex>","hash":"<hex>"}]'
AUTH_USERS=
